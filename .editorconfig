root = true

# =============================================================================
# DEFAULT SETTINGS FOR ALL FILES
# =============================================================================
[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# =============================================================================
# PYTHON (PEP8)
# =============================================================================
[*.py]
indent_size = 4
max_line_length = 79

# =============================================================================
# JAVASCRIPT / TYPESCRIPT / HTML
# =============================================================================
[*.js]
indent_size = 2

[*.jsx]
indent_size = 2

[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2

[*.html]
indent_size = 2

# =============================================================================
# JSON / YAML / CONFIG FILES
# =============================================================================
[*.json]
indent_size = 2

[*.jsonc]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

# =============================================================================
# MARKDOWN
# =============================================================================
[*.md]
trim_trailing_whitespace = false

# =============================================================================
# SHELL SCRIPTS
# =============================================================================
[*.sh]
indent_size = 2

# =============================================================================
# MAKEFILE (tabs required)
# =============================================================================
[Makefile]
indent_style = tab

# =============================================================================
# EDITORCONFIG FILE ITSELF
# =============================================================================
[*.editorconfig]
indent_size = 2
